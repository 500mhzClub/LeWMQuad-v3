#!/usr/bin/env python3
"""Manage LeWM episode boundaries via /lewm/go2/reset.

Owns the monotonic episode/reset counters and, when the caller sets
`use_spawn_pose=true`, teleports the robot to the requested pose by shelling
out to `gz service -s /world/<world>/set_pose`. Velocity is not explicitly
zeroed: the CHAMP controller and EKF will see a brief discontinuity after a
teleport, which is acceptable for episode boundaries (cross-reset training
windows are excluded downstream by the dataset loader).
"""

from __future__ import annotations

import subprocess

import rclpy
from geometry_msgs.msg import Pose
from rclpy.node import Node

from lewm_go2_control.msg import ResetEvent
from lewm_go2_control.srv import ResetEpisode


class ResetManager(Node):
    def __init__(self) -> None:
        super().__init__("lewm_go2_reset_manager")

        self.declare_parameter("reset_service", "/lewm/go2/reset")
        self.declare_parameter("reset_event_topic", "/lewm/go2/reset_event")
        self.declare_parameter("initial_episode_id", 0)
        self.declare_parameter("enable_teleport", True)
        self.declare_parameter("world_name", "default")
        self.declare_parameter("entity_name", "go2")
        self.declare_parameter("gz_service_timeout_ms", 2000)

        self._episode_id = int(self.get_parameter("initial_episode_id").value)
        self._reset_count = 0
        self._enable_teleport = bool(self.get_parameter("enable_teleport").value)
        self._world_name = str(self.get_parameter("world_name").value)
        self._entity_name = str(self.get_parameter("entity_name").value)
        self._gz_timeout_ms = int(self.get_parameter("gz_service_timeout_ms").value)

        self._event_pub = self.create_publisher(
            ResetEvent, str(self.get_parameter("reset_event_topic").value), 10
        )
        self._service = self.create_service(
            ResetEpisode,
            str(self.get_parameter("reset_service").value),
            self._on_reset,
        )

        self.get_logger().info(
            "Reset manager ready: service="
            f"{self.get_parameter('reset_service').value}, "
            f"event_topic={self.get_parameter('reset_event_topic').value}, "
            f"initial_episode_id={self._episode_id}, "
            f"enable_teleport={self._enable_teleport}, "
            f"world={self._world_name}, entity={self._entity_name}"
        )

    def _on_reset(
        self, request: ResetEpisode.Request, response: ResetEpisode.Response
    ) -> ResetEpisode.Response:
        self._episode_id += 1
        self._reset_count += 1

        teleport_attempted = bool(request.use_spawn_pose) and self._enable_teleport
        teleport_ok = True
        teleport_message = ""
        if teleport_attempted:
            teleport_ok, teleport_message = self._teleport(request.spawn_pose_world)

        if request.use_spawn_pose and not self._enable_teleport:
            response_message = (
                "episode bookkeeping advanced; teleport requested but disabled "
                "by enable_teleport=false"
            )
            overall_success = True
        elif teleport_attempted and not teleport_ok:
            response_message = (
                f"episode bookkeeping advanced; teleport failed: {teleport_message}"
            )
            overall_success = False
        elif teleport_attempted and teleport_ok:
            response_message = "episode bookkeeping advanced; physical teleport applied"
            overall_success = True
        else:
            response_message = "episode bookkeeping advanced"
            overall_success = True

        response.success = overall_success
        response.episode_id = self._episode_id
        response.reset_count = self._reset_count
        response.message = response_message

        event = ResetEvent()
        event.header.stamp = self.get_clock().now().to_msg()
        event.scene_id = request.scene_id
        event.episode_id = self._episode_id
        event.reset_count = self._reset_count
        event.reason = request.reason
        event.success = overall_success
        event.spawn_pose_world = request.spawn_pose_world
        self._event_pub.publish(event)

        self.get_logger().info(
            f"reset accepted: scene_id={request.scene_id} "
            f"episode_id={self._episode_id} reset_count={self._reset_count} "
            f"reason='{request.reason}' "
            f"teleport_attempted={teleport_attempted} teleport_ok={teleport_ok}"
        )
        return response

    def _teleport(self, pose: Pose) -> tuple[bool, str]:
        qx = float(pose.orientation.x)
        qy = float(pose.orientation.y)
        qz = float(pose.orientation.z)
        qw = float(pose.orientation.w)
        if abs(qw) + abs(qx) + abs(qy) + abs(qz) < 1e-6:
            qw = 1.0

        service = f"/world/{self._world_name}/set_pose"
        request_text = (
            f'name: "{self._entity_name}", '
            f"position: {{x: {pose.position.x}, y: {pose.position.y}, "
            f"z: {pose.position.z}}}, "
            f"orientation: {{x: {qx}, y: {qy}, z: {qz}, w: {qw}}}"
        )

        try:
            result = subprocess.run(
                [
                    "gz", "service",
                    "-s", service,
                    "--reqtype", "gz.msgs.Pose",
                    "--reptype", "gz.msgs.Boolean",
                    "--timeout", str(self._gz_timeout_ms),
                    "--req", request_text,
                ],
                check=False,
                capture_output=True,
                text=True,
                timeout=self._gz_timeout_ms / 1000.0 + 1.0,
            )
        except FileNotFoundError:
            return False, "gz CLI not found in PATH"
        except subprocess.TimeoutExpired:
            return False, "gz service call exceeded subprocess timeout"

        if result.returncode != 0:
            return False, (
                f"gz service exited with code {result.returncode}: "
                f"{result.stderr.strip() or result.stdout.strip()}"
            )

        if "true" not in result.stdout.lower():
            return False, f"gz service response not ok: {result.stdout.strip()}"

        return True, "set_pose acknowledged"


def main() -> None:
    rclpy.init()
    node = ResetManager()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()
