#!/usr/bin/env python3
"""Publish LeWM Go2 BaseState from the configured odometry stream."""

from __future__ import annotations

import math

import rclpy
from geometry_msgs.msg import Pose, Twist, Vector3
from nav_msgs.msg import Odometry
from rclpy.node import Node

from lewm_go2_control.msg import BaseState


class BaseStatePublisher(Node):
    def __init__(self) -> None:
        super().__init__("lewm_go2_base_state_publisher")

        self.declare_parameter("odom_topic", "/odom")
        self.declare_parameter("base_state_topic", "/lewm/go2/base_state")

        self._base_state_pub = self.create_publisher(
            BaseState, str(self.get_parameter("base_state_topic").value), 10
        )
        self._odom_sub = self.create_subscription(
            Odometry,
            str(self.get_parameter("odom_topic").value),
            self._on_odom,
            10,
        )

        self.get_logger().info(
            "BaseState publisher ready: "
            f"{self.get_parameter('odom_topic').value} -> "
            f"{self.get_parameter('base_state_topic').value}"
        )

    def _on_odom(self, msg: Odometry) -> None:
        out = BaseState()
        out.header = msg.header

        pose_world = Pose()
        pose_world.position = msg.pose.pose.position
        pose_world.orientation = msg.pose.pose.orientation
        out.pose_world = pose_world

        twist_body = Twist()
        twist_body.linear = msg.twist.twist.linear
        twist_body.angular = msg.twist.twist.angular
        out.twist_body = twist_body

        qx = msg.pose.pose.orientation.x
        qy = msg.pose.pose.orientation.y
        qz = msg.pose.pose.orientation.z
        qw = msg.pose.pose.orientation.w

        linear_world = _rotate_body_to_world(
            twist_body.linear.x, twist_body.linear.y, twist_body.linear.z, qx, qy, qz, qw
        )
        angular_world = _rotate_body_to_world(
            twist_body.angular.x, twist_body.angular.y, twist_body.angular.z, qx, qy, qz, qw
        )
        twist_world = Twist()
        twist_world.linear = Vector3(x=linear_world[0], y=linear_world[1], z=linear_world[2])
        twist_world.angular = Vector3(x=angular_world[0], y=angular_world[1], z=angular_world[2])
        out.twist_world = twist_world

        out.quat_world_xyzw = [float(qx), float(qy), float(qz), float(qw)]
        roll, pitch, yaw = _quat_to_rpy(qx, qy, qz, qw)
        out.roll_rad = float(roll)
        out.pitch_rad = float(pitch)
        out.yaw_rad = float(yaw)

        self._base_state_pub.publish(out)


def _rotate_body_to_world(
    vx: float, vy: float, vz: float, qx: float, qy: float, qz: float, qw: float
) -> tuple[float, float, float]:
    xx = qx * qx
    yy = qy * qy
    zz = qz * qz
    xy = qx * qy
    xz = qx * qz
    yz = qy * qz
    wx = qw * qx
    wy = qw * qy
    wz = qw * qz

    r00 = 1.0 - 2.0 * (yy + zz)
    r01 = 2.0 * (xy - wz)
    r02 = 2.0 * (xz + wy)
    r10 = 2.0 * (xy + wz)
    r11 = 1.0 - 2.0 * (xx + zz)
    r12 = 2.0 * (yz - wx)
    r20 = 2.0 * (xz - wy)
    r21 = 2.0 * (yz + wx)
    r22 = 1.0 - 2.0 * (xx + yy)

    x = r00 * vx + r01 * vy + r02 * vz
    y = r10 * vx + r11 * vy + r12 * vz
    z = r20 * vx + r21 * vy + r22 * vz
    return x, y, z


def _quat_to_rpy(qx: float, qy: float, qz: float, qw: float) -> tuple[float, float, float]:
    sinr_cosp = 2.0 * (qw * qx + qy * qz)
    cosr_cosp = 1.0 - 2.0 * (qx * qx + qy * qy)
    roll = math.atan2(sinr_cosp, cosr_cosp)

    sinp = 2.0 * (qw * qy - qz * qx)
    sinp = max(-1.0, min(1.0, sinp))
    pitch = math.asin(sinp)

    siny_cosp = 2.0 * (qw * qz + qx * qy)
    cosy_cosp = 1.0 - 2.0 * (qy * qy + qz * qz)
    yaw = math.atan2(siny_cosp, cosy_cosp)
    return roll, pitch, yaw


def main() -> None:
    rclpy.init()
    node = BaseStatePublisher()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()
