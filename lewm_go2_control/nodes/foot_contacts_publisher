#!/usr/bin/env python3
"""Republish CHAMP's kinematic foot contacts as the LeWM FootContacts msg.

CHAMP exposes a per-leg gait-phase boolean stream on `/foot_contacts`
(`champ_msgs/ContactsStamped`) when `gazebo: False` and
`publish_foot_contacts: True`. The booleans come from
`base_.legs[i]->gait_phase()` in the upstream `quadruped_controller`, so
they describe the planned stance/swing state from the gait planner -- not
sensor-derived ground contact. This is the contact signal CHAMP itself
uses when there is no real per-foot sensor feedback.

We chose this over Gazebo `contact` sensors because the latter, combined
with the `gz-sim-contact-system` plugin under `bullet-featherstone`,
destabilizes CHAMP's effort-tracked gait within ~6 s of /cmd_vel. The
sensor declarations themselves were inert (test in commit log); the cost
came from the per-tick contact processing inside gz. CHAMP's kinematic
signal has zero physics interaction and recovers gait endurance fully.

CHAMP's leg order is `lf, rf, lh, rh`; LeWM's field names are
`fl, fr, rl, rr`. The mapping below is:
- lf -> fl
- rf -> fr
- lh -> rl
- rh -> rr

The `*_force_n` fields are set to 0.0. The kinematic signal is a
boolean-only contract; downstream consumers that need per-foot forces
must derive them elsewhere (e.g. from inverse dynamics on joint efforts).
"""

from __future__ import annotations

import rclpy
from champ_msgs.msg import ContactsStamped
from rclpy.node import Node

from lewm_go2_control.msg import FootContacts


class FootContactsPublisher(Node):
    def __init__(self) -> None:
        super().__init__("lewm_go2_foot_contacts_publisher")

        self.declare_parameter("champ_topic", "/foot_contacts")
        self.declare_parameter("foot_contacts_topic", "/lewm/go2/foot_contacts")
        self.declare_parameter("frame_id", "base_link")

        self._frame_id = str(self.get_parameter("frame_id").value)

        self._pub = self.create_publisher(
            FootContacts, str(self.get_parameter("foot_contacts_topic").value), 10
        )
        self._sub = self.create_subscription(
            ContactsStamped,
            str(self.get_parameter("champ_topic").value),
            self._on_contacts,
            10,
        )

        self.get_logger().info(
            f"FootContacts republisher ready: "
            f"{self.get_parameter('champ_topic').value} -> "
            f"{self.get_parameter('foot_contacts_topic').value}"
        )

    def _on_contacts(self, msg: ContactsStamped) -> None:
        if len(msg.contacts) < 4:
            return
        out = FootContacts()
        out.header.stamp = msg.header.stamp
        out.header.frame_id = self._frame_id
        # CHAMP leg order: lf, rf, lh, rh -> LeWM: fl, fr, rl, rr
        out.fl_contact = bool(msg.contacts[0])
        out.fr_contact = bool(msg.contacts[1])
        out.rl_contact = bool(msg.contacts[2])
        out.rr_contact = bool(msg.contacts[3])
        out.fl_force_n = 0.0
        out.fr_force_n = 0.0
        out.rl_force_n = 0.0
        out.rr_force_n = 0.0
        self._pub.publish(out)


def main() -> None:
    rclpy.init()
    node = FootContactsPublisher()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.destroy_node()
        if rclpy.ok():
            rclpy.shutdown()


if __name__ == "__main__":
    main()
